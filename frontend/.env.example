# Frontend environment variables
#
# The service layer (src/services/index.js) selects the in-repo mock vs the real
# backend from VITE_USE_MOCK. With the mock on, the temporary UI runs with no
# backend at all.

# "true" => use src/services/mock (no backend needed). Anything else => real API.
VITE_USE_MOCK=true

# Base URL of the backend API (used when VITE_USE_MOCK is not "true").
VITE_API_URL=http://localhost:3000
